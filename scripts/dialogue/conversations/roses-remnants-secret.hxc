import flixel.tweens.FlxEase;
import flixel.tweens.FlxTween;
import funkin.play.cutscene.dialogue.Conversation;
import funkin.audio.FunkinSound;

class RosesRemnantsSecretConversation extends Conversation
{
  var beema:FunkinSound;

  function new()
  {
    super('roses-remnants-secret');
  }

  override function onCreate(event:ScriptEvent):Void
  {
    super.onCreate(event);
    beema = FunkinSound.load(Paths.sound('Beema', "week6"), 1);
  }

  override function showCurrentSpeaker():Void
  {
    if (beema?.isPlaying) beema.stop();

    super.showCurrentSpeaker();

    switch (currentSpeaker.id)
    {
      case 'bf-pixel-remnants':
        FunkinSound.playOnce(Paths.sound('gameplay/secret/secret', "shared"), 0.5);
        beema.play();
    }
  }
}
